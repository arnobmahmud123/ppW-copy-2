NEXTAUTH_URL=https://your-vercel-domain.vercel.app
NEXTAUTH_SECRET=replace-with-a-long-random-secret
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Postgres connection string for local or hosted environments.
# Example local value:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ppw_web?schema=public
# Example Vercel Postgres value:
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=replace-with-your-postgres-database-url

# Optional social login providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Optional AI features
OPENAI_API_KEY=
OPENAI_BID_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_BID_MODEL=gemini-2.5-flash
GEMINI_TRANSLATE_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Optional server-side knowledge directory for message AI.
# On Vercel this must point to an accessible runtime path or be left unset.
MESSAGE_AI_KNOWLEDGE_DIR=
